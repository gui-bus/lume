generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String   @id @default(uuid())
  email   String   @unique
  name    String?
  resumes Resume[]
}

model Resume {
  id         String   @id @default(uuid())
  title      String
  content    Json
  colorTheme String   @default("#000000")
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
